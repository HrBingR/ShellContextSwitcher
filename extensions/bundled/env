env_on_up() {
  local env_file="$SCS_EXTENSION_CONFIG"
  local key value filepath
  while read -r env || [[ -n "$env" ]]; do
    key="${env%%=*}"
    value="${env#*=}"
    if [[ "$value" == "<"* ]]; then
      filepath="${value#<}"
      filepath="${filepath/#\~/$HOME}"
      if [[ -f "$filepath" ]]; then
        value="$(<"$filepath")"
      else
        echo "Warning: File not found: $filepath (for $key)" >&2
        continue
      fi
    fi
    export "$key=$value"
  done < "$env_file"
  return 0
}

env_on_down() {
  local env_file="$SCS_EXTENSION_CONFIG"
  while read -r env || [[ -n "$env" ]]; do
    unset "${env%%=*}"
  done < "$env_file"
  return 0
}

env_on_show() {
  local env_file="$SCS_EXTENSION_CONFIG"
  local -a found_env=()
  local env_name
  local current_value

  while IFS='=' read -r env_name _ || [[ -n "$env_name" ]]; do
    if current_value=$(printenv "$env_name" 2>/dev/null); then
      found_env+=("$env_name=$current_value")
    fi
  done < "$env_file"

  if (( ${#found_env[@]} == 0 )); then
    echo "No configured environment variables found in the current environment. Please reload the current profile."
  else
    echo "Current environment variables for selected profile:"
    echo
    printf '%s\n' "${found_env[@]}"
    echo
  fi
  return 0
}

env_on_help() {
  echo "This extension is used to configure environment variables for your currently-selected profile"
  echo "Simply create a file called 'env' in your profiles/<profile> directory with the environment variables you wish you use."
  echo "The syntax is the same as you'd use in your shell's .rc file"
  echo
  echo "Do not wrap values in quotes - values are read literally, so special characters"
  echo "like \$, @, and spaces are preserved as-is. Quoting will embed the literal quote characters."
  echo
  echo "To read a value from a file, prefix the path with <:"
  echo "  VAULT_TOKEN=<~/tokens/my_token"
  echo
  echo "Here's an example env file:"
  echo "  AWS_PROFILE=my-profile"
  echo "  GIT_AUTHOR_NAME=somename"
  echo "  VAULT_TOKEN=</path/to/token"
}